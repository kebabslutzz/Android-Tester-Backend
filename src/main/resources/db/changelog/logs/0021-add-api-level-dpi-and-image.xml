<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="0021-add-api-level-dpi-and-image" author="kasparas.putrius">
    <addColumn tableName="test_device">
      <column name="api_level" type="INTEGER"/>
      <column name="system_image" type="VARCHAR(255)"/>
      <column name="dpi" type="INTEGER"/>
    </addColumn>

    <rollback>
      <dropColumn tableName="test_device" columnName="api_level"/>
      <dropColumn tableName="test_device" columnName="system_image"/>
      <dropColumn tableName="test_device" columnName="dpi"/>
    </rollback>
  </changeSet>
</databaseChangeLog>
